    "plt.suptitle(\"Selection du nombre optimal de topics\", fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nTop 5 par u_mass :\")\n",
    "print(df_grid.sort_values('u_mass', ascending=False).head(5).to_string(index=False))"
